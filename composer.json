{
    "name": "jansuchanek/npresence",
    "description": "Live user presence, heartbeat tracking, and activity logging for Nette Framework",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "doctrine/dbal": "^3.0|^4.0"
    },
    "require-dev": {
        "nette/tester": "^2.6",
        "nette/di": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "NPresence\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NPresence\\Tests\\": "tests/"
        }
    }
}
